# --- Required -------------------------------------------------------------
# Single password gating the dashboard. Generate with: openssl rand -hex 32
DASHBOARD_PASSWORD=

# --- Garmin Connect (primary activity + wellness source) ------------------
# No env vars — connect once interactively at /auth/garmin (username +
# password; tokens are persisted to the cache).

# --- Intervals.icu (optional) ---------------------------------------------
# Generate an API key: https://intervals.icu/settings (API section)
INTERVALS_ICU_API_KEY=
INTERVALS_ICU_ATHLETE_ID=

# --- Garmin Connect (optional) --------------------------------------------
# No env vars: connect at /auth/garmin with your Garmin email + password.
# Tokens are persisted to your KV/file cache.

# --- MCP server (optional) ------------------------------------------------
# Static bearer token for legacy MCP clients (e.g. Claude Desktop).
# Generate with: openssl rand -hex 32
MCP_SECRET_TOKEN=

# --- Redis cache (optional) -----------------------------------------------
# Required for production (Vercel functions are stateless).
# Locally, leave empty to use file cache at .data/cache.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Profile defaults -----------------------------------------------------
# Used to derive HR zones (Z1<60% .. Z5>=90% of max).
HR_MAX_BPM=190
# Default target wattage for HR-at-power trend.
DEFAULT_TARGET_WATTS=190
