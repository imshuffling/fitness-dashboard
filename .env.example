# --- Required -------------------------------------------------------------
# Single password gating the dashboard. Generate with: openssl rand -hex 32
DASHBOARD_PASSWORD=

# --- Intervals.icu (required — primary data source) ------------------------
# Activities, streams, athlete profile, and training load all come from here.
# Sync your trainers/watches directly to intervals.icu (Zwift, Garmin, etc.)
# — Strava-sourced activities are not readable via the intervals.icu API.
# Generate an API key: https://intervals.icu/settings (API section)
INTERVALS_ICU_API_KEY=
INTERVALS_ICU_ATHLETE_ID=

# --- Strava (optional — activity photos only) ------------------------------
# Only used to fetch photos/videos for activities that intervals.icu links
# to a Strava activity (strava_id). Safe to leave empty.
# Create an API app: https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:3000/auth/strava/callback

# --- Garmin Connect (optional) --------------------------------------------
# No env vars: connect at /auth/garmin with your Garmin email + password.
# Tokens are persisted to your KV/file cache.

# --- MCP server (optional) ------------------------------------------------
# Static bearer token for legacy MCP clients (e.g. Claude Desktop).
# Generate with: openssl rand -hex 32
MCP_SECRET_TOKEN=

# --- Redis cache (optional) -----------------------------------------------
# Required for production (Vercel functions are stateless).
# Locally, leave empty to use file cache at .data/cache.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Profile defaults -----------------------------------------------------
# Used to derive HR zones (Z1<60% .. Z5>=90% of max).
HR_MAX_BPM=190
# Default target wattage for HR-at-power trend.
DEFAULT_TARGET_WATTS=190
